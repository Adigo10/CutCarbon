# Copy to .env and fill in. All values are read once at process start.

# OpenAI — required for the chat co-pilot (503 on chat endpoints if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# TinyFish — required for live emission-factor refresh agents (agents skip if unset)
TINYFISH_API_KEY=

# --- Database (Supabase Postgres) ------------------------------------------------
# App runtime uses the TRANSACTION pooler (port 6543) with the LEAST-PRIVILEGE app role
# (created by the b2c3d4e5f6a7 migration; set its password in the Supabase SQL editor):
#   postgresql+asyncpg://cutcarbon_app.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Get the host/region from Supabase -> Project Settings -> Database -> Connection string.
# A sqlite+aiosqlite:// URL still works as a local dev fallback.
DATABASE_URL=sqlite+aiosqlite:///./cutcarbon.db

# Alembic migrations use this if set, else DATABASE_URL. Use the ELEVATED `postgres`
# role on the SESSION pooler (5432) or the direct connection — migrations need DDL /
# ownership and prepared statements, which the transaction pooler forbids.
#   postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
MIGRATION_DATABASE_URL=

# Run `alembic upgrade head` from the app lifespan on startup. Leave false in prod
# (apply migrations out-of-band); enable only for single-instance dev/demo.
RUN_MIGRATIONS_ON_STARTUP=false

# --- Supabase Auth ---------------------------------------------------------------
# Base project URL, e.g. https://abcxyz.supabase.co. Used to derive the JWKS endpoint
# and the expected token issuer. FastAPI verifies Supabase-issued access tokens; it
# no longer mints JWTs (signup/login happen client-side via supabase-js).
SUPABASE_URL=
# Audience Supabase stamps on user tokens (rarely changed).
SUPABASE_JWT_AUD=authenticated
# Optional HS256 shared secret (legacy JWT secret). Leave empty for asymmetric-only
# (RS256/ES256 verified via the JWKS endpoint).
SUPABASE_JWT_SECRET=

# Comma-separated emails allowed to trigger TinyFish agent runs (which mutate the
# global emission-factor file and scrape external sites). Empty = nobody.
ADMIN_EMAILS=

# Per-IP rate limiting (login/register happen in Supabase; chat 20/min, agents 2/hour).
RATE_LIMIT_ENABLED=true

APP_HOST=0.0.0.0
APP_PORT=8000

# --- Frontend (frontend/.env, read by Vite at build time) ------------------------
# VITE_API_URL=http://127.0.0.1:8000
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # safe for the browser (RLS-protected)

# --- Tests -----------------------------------------------------------------------
# Tests run against real Postgres. Provide a direct/session connection (NOT the 6543
# transaction pooler), or install Docker so testcontainers can spin up postgres:15.
# TEST_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cutcarbon_test
