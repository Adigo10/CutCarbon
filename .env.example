# Copy to .env and fill in. All values are read once at process start.

# OpenAI — required for the chat co-pilot (503 on chat endpoints if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# TinyFish — required for live emission-factor refresh agents (agents skip if unset)
TINYFISH_API_KEY=

# Database. SQLite locally; for Postgres use postgresql+asyncpg://user:pass@host/db
# (and add asyncpg to requirements).
DATABASE_URL=sqlite+aiosqlite:///./cutcarbon.db

# JWT signing secret — MUST be a random string of at least 32 characters.
# If unset/placeholder/too short, an ephemeral per-process secret is generated
# and tokens will not survive a restart. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080

# Comma-separated emails allowed to trigger TinyFish agent runs (these mutate the
# global emission-factor file and scrape external sites). Empty = nobody.
ADMIN_EMAILS=

# Per-IP rate limiting (register/login 5/min, chat 20/min, agent runs 2/hour).
RATE_LIMIT_ENABLED=true

APP_HOST=0.0.0.0
APP_PORT=8000
